{
  "name": "moments",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Moments — a premium social app for sharing your best moments. Photos, videos, reels, stories & chat. React + Express + PostgreSQL.",
  "scripts": {
    "dev": "concurrently -n API,WEB -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.js",
    "db:setup": "node server/setup.js",
    "db:seed": "node server/seed.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
