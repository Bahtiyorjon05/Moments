# ── Server ──────────────────────────────────────────────
PORT=4000
JWT_SECRET=replace_with_a_long_random_secret
ENCRYPTION_KEY=replace_with_a_long_random_key   # AES key for reversible password storage
CLIENT_ORIGIN=http://localhost:5173

# ── Local PostgreSQL ────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password
PGDATABASE=moments

# ── Frontend (Vite) ─────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
